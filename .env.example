# Environment variables for configuring application settings
# Server Configuration
APP_NAME=your_app_name
APP_HEADERS_NAME=your_custom_header_name
APP_VERSION=your_app_version
APP_PORT=your_app_port
ALLOW_ORIGINS=your_allowed_origins
ALLOW_METHODS=your_allowed_methods
ALLOW_HEADERS=your_allowed_headers
APP_READ_TIMEOUT=your_read_timeout
APP_WRITE_TIMEOUT=your_write_timeout
APP_IDLE_TIMEOUT=your_idle_timeout

# Database Configuration
DB_DRIVER=your_db_driver
MAX_OPEN_CONNECTIONS=your_max_open_connections
MAX_IDLE_CONNECTIONS=your_max_idle_connections
CONN_MAX_LIFETIME=your_conn_max_lifetime
CONN_MAX_IDLE_TIME=your_conn_max_idle_time

# GOOSE Migration Settings
GOOSE_DRIVER=your_goose_driver
GOOSE_DBSTRING=your_goose_dbstring
GOOSE_MIGRATION_DIR=your_goose_migration_dir